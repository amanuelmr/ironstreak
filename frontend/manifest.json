{
  "manifest_version": 3,
  "name": "Ironstreak",
  "version": "1.0.0",
  "description": "Personal accountability dashboard — run challenges, log progress, and keep your iron streak. All data stays in your browser.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": ["unlimitedStorage", "storage"],
  "background": {
    "service_worker": "src/sw.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Open Ironstreak",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "options_page": "options.html"
}
